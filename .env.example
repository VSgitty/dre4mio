# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://monopol:monopol-dev@localhost:5432/monopol

# ─── AI APIs ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
REPLICATE_API_KEY=r8_...
ELEVENLABS_API_KEY=...

# ─── Object Storage (S3 / Cloudflare R2) ─────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=auto
S3_BUCKET=monopol-studio
# For Cloudflare R2: https://<account>.r2.cloudflarestorage.com
S3_ENDPOINT=https://your-endpoint.r2.cloudflarestorage.com
CDN_URL=https://your-cdn.example.com

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_STUDIO=price_...

# ─── Internal Service URLs ────────────────────────────────────────────────────
API_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000
AI_SERVICE_URL=http://localhost:8000
RENDER_SERVICE_URL=http://localhost:5001

# ─── Next.js Public ──────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
