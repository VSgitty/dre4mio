{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@monopol/ui": ["../../packages/ui"],
      "@monopol/ui/*": ["../../packages/ui/*"],
      "@monopol/editor": ["../../packages/editor"],
      "@monopol/editor/*": ["../../packages/editor/*"],
      "@monopol/timeline": ["../../packages/timeline"],
      "@monopol/timeline/*": ["../../packages/timeline/*"],
      "@monopol/types": ["../../packages/types"],
      "@monopol/types/*": ["../../packages/types/*"],
      "@monopol/shared": ["../../packages/shared"],
      "@monopol/shared/*": ["../../packages/shared/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", "**/*.d.ts", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
