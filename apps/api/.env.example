NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/monopol"

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# JWT
JWT_SECRET=your-secret-key-change-in-production

# Storage
S3_BUCKET_NAME=monopol-studio
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Or Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Redis
REDIS_URL=redis://localhost:6379

# AI APIs
OPENAI_API_KEY=
REPLICATE_API_TOKEN=
STABILITY_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email
SENDGRID_API_KEY=
MAIL_FROM=noreply@monopolstudio.com

# CORS
FRONTEND_URL=http://localhost:3000

# WebSocket
SOCKET_URL=http://localhost:3001
